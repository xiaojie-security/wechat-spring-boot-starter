# Compiled class file
*.class

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*
replay_pid*

# Maven 构建目录
target/

# 允许提交仓库内的本地 Maven 仓库产物
!maven-repository/
!maven-repository/**

# IntelliJ IDEA 工程目录
.idea/
!.idea/.gitignore
